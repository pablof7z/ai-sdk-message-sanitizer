{
  "name": "ai-sdk-message-sanitizer",
  "version": "0.1.0",
  "description": "AI SDK middleware that sanitizes malformed message arrays before LLM API calls",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "examples/*.ts",
    "examples/README.md",
    "examples/tsconfig.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "prepare": "bun run build",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "ai-sdk",
    "middleware",
    "message-sanitizer",
    "tool-ordering",
    "anthropic"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pablof7z/ai-sdk-message-sanitizer.git"
  },
  "peerDependencies": {
    "ai": ">=6.0.0",
    "@ai-sdk/provider": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@opentelemetry/api": {
      "optional": true
    }
  },
  "devDependencies": {
    "ai": "^6.0.116",
    "@ai-sdk/provider": "^3.0.8",
    "@opentelemetry/api": "^1.9.0",
    "@types/bun": "^1.2.0",
    "typescript": "^5.7.0"
  }
}
